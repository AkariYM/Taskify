<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Encabezado -->
    <LinearLayout
        android:id="@+id/headerPersonalizacion"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/splash_background"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/personalizacion_y_configuracion"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personaliza tu experiencia"
            android:textSize="14sp"
            android:textColor="#E0E0FF"/>

    </LinearLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="120dp">

        <!-- Temas -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Temas"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3700B3"/>

                <Button
                    android:id="@+id/buttonTemas"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/temas"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#6200EE"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Notificaciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Notificaciones"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3700B3"/>

                <Button
                    android:id="@+id/buttonNotificaciones"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/notificaciones_alarmas"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#6200EE"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ayuda -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ayuda Rápida"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3700B3"/>

                <Button
                    android:id="@+id/buttonAyuda"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/ayuda_rapida"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#6200EE"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Copia de seguridad -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Copia de Seguridad"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3700B3"/>

                <Button
                    android:id="@+id/buttonBackup"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/copia_de_seguridad"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#6200EE"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Editar Perfil -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Editar Perfil"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#3700B3"/>

                <Button
                    android:id="@+id/buttonEditarPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/editar_perfil"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#6200EE"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>