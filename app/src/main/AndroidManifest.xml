<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.taskifya">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskifyA">

        <!-- Receiver de personalización -->
        <receiver
            android:name=".personalizacion.RecordatorioReceiver"
            android:exported="false" />

        <!-- Activities de Usuario -->
        <activity
            android:name=".usuario.CambiarPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskifyA" />
        <activity
            android:name=".usuario.EditarPerfilActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskifyA" />
        <activity
            android:name=".usuario.RegistroActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskifyA" />
        <activity
            android:name=".usuario.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskifyA" />

        <!-- Activities de Personalización -->
        <activity
            android:name=".personalizacion.EditarPerfilActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionEditarPerfilActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionTemaActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionNotificacionesActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionAyudaRapidaActivity"
            android:exported="false" />
        <activity
            android:name=".personalizacion.PersonalizacionCopiaDeSeguridadActivity"
            android:exported="false" />

        <!-- Activities de Calendario -->
        <activity
            android:name=".eventos.CalendarioMenuActivity"
            android:exported="false" />
        <activity android:name=".eventos.CrearEventoActivity" />
        <activity android:name=".eventos.CrearRecordatorioActivity" />
        <activity android:name=".eventos.FiltrarEventosActivity" />
        <activity android:name=".eventos.CalendarioActivity" />
        <activity android:name=".eventos.EditarEventoActivity" />

        <!-- MainActivity — pantalla de inicio general -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TaskifyA">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>